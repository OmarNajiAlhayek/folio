@startuml folio-reader-use-cases
' Folio — Reader essentials (public / unauthenticated; not an RBAC role)
' AI: semantic catalog search, related articles (docs/plans/ai-service.md)
' Render: https://www.plantuml.com/plantuml

left to right direction
skinparam packageStyle rectangle
skinparam actorStyle stickman

actor "Reader" as RD

rectangle "Folio — reader scope" {

  usecase "Discover published articles" as UC_Discover
  usecase "Browse publication catalog" as UC_Browse
  usecase "Search catalog by text" as UC_Keyword
  usecase "View publication detail" as UC_Detail
  usecase "Download public manuscript" as UC_Download

  usecase "Search catalog semantically (AI)" as UC_AiSemantic
  usecase "View related articles (AI)" as UC_AiRelated
}

RD --> UC_Discover

UC_Discover .> UC_Browse : <<include>>
UC_Discover .> UC_Keyword : <<include>>
UC_Discover .> UC_Detail : <<include>>
UC_AiSemantic .> UC_Keyword : <<extend>>
UC_AiRelated .> UC_Detail : <<extend>>
UC_Download .> UC_Detail : <<extend>>


@enduml

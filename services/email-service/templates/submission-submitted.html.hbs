{{#> folio-email-layout dir="ltr" lang="en"}}
<p style="margin:0 0 16px;">Dear {{editorDisplayName}},</p>
{{#if isResubmission}}
<p style="margin:0 0 16px;">
  <strong>{{authorDisplayName}}</strong> has resubmitted a revised manuscript:
  <strong>{{submissionTitle}}</strong>.
</p>
{{else}}
<p style="margin:0 0 16px;">
  <strong>{{authorDisplayName}}</strong> has submitted a new manuscript:
  <strong>{{submissionTitle}}</strong>.
</p>
{{/if}}
{{> folio-email-button href=editorQueueUrl label="Open editor queue" align="left"}}
<p style="margin:24px 0 0;">Thank you,<br />Folio editorial team</p>
{{/folio-email-layout}}

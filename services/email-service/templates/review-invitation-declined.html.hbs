{{#> folio-email-layout dir="ltr" lang="en"}}
<p style="margin:0 0 16px;">Dear {{editorDisplayName}},</p>
<table role="presentation" width="100%" cellspacing="0" cellpadding="0" border="0" style="margin:0 0 16px;">
  <tr>
    <td style="background-color:#fffbeb;border:1px solid #fde68a;border-radius:6px;padding:14px 16px;">
      <strong>{{reviewerDisplayName}}</strong> declined the review invitation for
      <strong>{{submissionTitle}}</strong>. You may need to assign another reviewer.
    </td>
  </tr>
</table>
{{> folio-email-button href=submissionUrl label="Open submission" align="left"}}
<p style="margin:24px 0 0;">Thank you,<br />Folio editorial team</p>
{{/folio-email-layout}}

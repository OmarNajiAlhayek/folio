# Folio email-service configuration.
# Copy to `.env` and fill in for local development.

# --- PostgreSQL --------------------------------------------------------------
# Reuse the same DB as the backend, but pin to a separate schema so the
# two apps never write to each other's tables (plan §6: migrations).
# Dev: changeme is fine locally. Production: startup fails on example passwords.
DB_HOST=localhost
DB_PORT=5432
DB_USERNAME=postgres
DB_PASSWORD=changeme
DB_DATABASE=folio
DB_SCHEMA=email

# --- RabbitMQ ----------------------------------------------------------------
# Must match the backend's RABBITMQ_URL/RABBITMQ_EXCHANGE so both apps
# talk to the same exchange. Default URL targets docker-compose.dev.yml.
RABBITMQ_URL=amqp://guest:guest@localhost:5672
RABBITMQ_EXCHANGE=folio.events

# --- Email provider ----------------------------------------------------------
# `noop` logs would-be sends and is the default in dev. Switch to `smtp`
# once you've picked a real vendor (Resend/Mailgun/etc. can be added by
# implementing EmailProvider in src/providers/).
EMAIL_PROVIDER=noop
EMAIL_FROM=no-reply@folio.local

# Required when EMAIL_PROVIDER=smtp:
# SMTP_HOST=smtp.example.com
# SMTP_PORT=587
# SMTP_SECURE=false
# SMTP_USER=
# SMTP_PASS=

# --- Reminder cadence --------------------------------------------------------
# Reviewer due-date offset in days. Reminders are scheduled relative to
# this value: due-soon at (REVIEW_DUE_IN_DAYS - 3), overdue at
# (REVIEW_DUE_IN_DAYS + 1).
REVIEW_DUE_IN_DAYS=21

# --- Health (orchestrator probes) --------------------------------------------
HEALTH_PORT=5244

# --- App base URL ------------------------------------------------------------
# Used inside reminder emails to build assignment links. Rules:
#   - No trailing slash.
#   - HTTPS in staging/production.
#   - http://localhost:5240 only when NODE_ENV=development.
APP_BASE_URL=http://localhost:5240

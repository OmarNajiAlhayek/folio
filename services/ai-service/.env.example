# Folio ai-service configuration.
# Copy to `.env` for local development.

# --- Runtime ---------------------------------------------------------------
APP_ENV=development
PORT=5245
GRPC_PORT=5246
LOG_LEVEL=info

# Set true to enforce production-style validation in local dev.
RUNTIME_CONFIG_STRICT=

# Shared secret for Nest → ai-service (gRPC metadata + HTTP /v1/classify/*).
# When set, internal callers must send X-Folio-Service-Token / x-folio-service-token.
AI_SERVICE_TOKEN=

# --- AI provider -----------------------------------------------------------
# `noop` is the default: no external API calls (safe for local dev).
# `openai` uses the OpenAI-compatible HTTP API (or OPENAI_BASE_URL override).
AI_PROVIDER=noop

# Required when AI_PROVIDER=openai (and in production / strict mode).
OPENAI_API_KEY=

# Optional: Azure OpenAI, local gateways (Ollama, LiteLLM, etc.)
# OPENAI_BASE_URL=https://api.openai.com/v1

OPENAI_MODEL=gpt-4o-mini

# --- AraBERT discipline classifier (optional) ------------------------------
# Enable dev routes: GET/POST /v1/classify/*
# Requires: pip install -e ".[ml]" and fine-tuned weights on disk.
ARABERT_ENABLED=false
# Preload tokenizer + weights at startup when true (avoids ~1 min first UI classify).
ARABERT_WARMUP_ON_STARTUP=true
# ARABERT_MODEL_PATH=
# ARABERT_PREPROCESSOR_MODEL=aubmindlab/bert-base-arabertv02
# ARABERT_DEFAULT_THRESHOLD=0.0
# ARABERT_IDLE_TIMEOUT_SECONDS=300

# --- Reader related articles (Chroma + embeddings) -------------------------
# Requires: pip install -e ".[similarity]"
SIMILARITY_ENABLED=false
# SIMILARITY_CHROMA_PATH=./data/chroma_similarity
# SIMILARITY_DEFAULT_LIMIT=5
# SIMILARITY_DEFAULT_THRESHOLD=0.35
# SIMILARITY_SAME_CATEGORY_ONLY=true
# SIMILARITY_DEVICE=cpu

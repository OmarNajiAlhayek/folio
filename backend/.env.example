# PostgreSQL Database Configuration
# Dev: changeme is fine locally. Production: the API refuses example/weak passwords.
DB_TYPE=postgres
DB_HOST=localhost
DB_PORT=5432
DB_USERNAME=postgres
DB_PASSWORD=changeme
DB_DATABASE=folio_review

# API
PORT=5243
# Comma-separated for multiple dev origins (e.g. localhost vs 127.0.0.1).
FRONTEND_ORIGIN=http://localhost:5240,http://127.0.0.1:5240

# OpenAPI / Swagger UI at http://localhost:<PORT>/api-docs (JSON at /api-docs-json).
# Enabled automatically when NODE_ENV is not production. Set to true to force on in production.
SWAGGER_ENABLED=

# JWT — dev placeholder only. Production: set NODE_ENV=production and use a unique
# random string (≥32 chars); startup fails if this example value is still set.
JWT_SECRET=change_this_to_a_long_random_secret
JWT_EXPIRES_IN=7d

# Auth cookies (browser uses httpOnly folio_access via Next.js proxy)
AUTH_COOKIE_SECURE=false
# Return accessToken in login/register JSON for Playwright/scripts only
AUTH_RETURN_BEARER=false

# Rate limits (POST /auth/login and /auth/register)
THROTTLE_TTL_MS=60000
THROTTLE_LOGIN_LIMIT=10
THROTTLE_REGISTER_LIMIT=5

# Outbound mail: configure ONLY in services/email-service/.env (EMAIL_PROVIDER, SMTP_*).
# Do not set EMAIL_PROVIDER or SMTP_* here — the backend will refuse to start.

# Uploads (relative to backend cwd)
UPLOAD_DIR=../uploads

# RabbitMQ (used to publish ReviewerInvited / ReminderDue events to the
# email-service). Default URL targets the local docker-compose.dev.yml
# rabbitmq container.
RABBITMQ_URL=amqp://guest:guest@localhost:5672
RABBITMQ_EXCHANGE=folio.events
# Cache TTL (ms) for passive RabbitMQ queue depth checks used by GET /admin/email/pipeline-status
EMAIL_QUEUE_METRICS_CACHE_MS=20000

# Public base URL of the frontend; used to build accept/decline links
# inside ReviewerInvited events. Rules:
#   - No trailing slash.
#   - HTTPS in staging/production.
#   - http://localhost:5240 only when NODE_ENV=development.
APP_BASE_URL=http://localhost:5240

# Optional: override compile-time default (`damascus-university-journal-v1`) when valid in registry.
DEFAULT_MANUSCRIPT_STYLE_ID=

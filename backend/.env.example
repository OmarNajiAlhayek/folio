# PostgreSQL Database Configuration
DB_TYPE=postgres
DB_HOST=localhost
DB_PORT=5432
DB_USERNAME=postgres
DB_PASSWORD=changeme
DB_DATABASE=folio_review

# API
PORT=5243
FRONTEND_ORIGIN=http://localhost:5240

# OpenAPI / Swagger UI at http://localhost:<PORT>/api-docs (JSON at /api-docs-json).
# Enabled automatically when NODE_ENV is not production. Set to true to force on in production.
SWAGGER_ENABLED=

# JWT (use a long random string in production)
JWT_SECRET=change_this_to_a_long_random_secret
JWT_EXPIRES_IN=7d

# Uploads (relative to backend cwd)
UPLOAD_DIR=../uploads

# RabbitMQ (used to publish ReviewerInvited / ReminderDue events to the
# email-service). Default URL targets the local docker-compose.dev.yml
# rabbitmq container.
RABBITMQ_URL=amqp://guest:guest@localhost:5672
RABBITMQ_EXCHANGE=folio.events

# Public base URL of the frontend; used to build accept/decline links
# inside ReviewerInvited events. Rules:
#   - No trailing slash.
#   - HTTPS in staging/production.
#   - http://localhost:5240 only when NODE_ENV=development.
APP_BASE_URL=http://localhost:5240
